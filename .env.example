# DayByDayWeb-HTML — environment variables
# Copy this file to .env and fill in the values you have.
# NEVER commit .env to git (already in .gitignore).

# ===== Google Search Console =====
# Path to the GSC service account JSON file (fine-grained PAT with webmasters scope).
# Default if unset: ~/Downloads/DAYBYDAY/Blog System/daybyday-gsc-ca41820f3bea.json
GSC_CREDENTIALS_PATH=/absolute/path/to/daybyday-gsc-XXXX.json

# Property URL in GSC. Must end with /.
# Default: https://www.daybydayconsulting.com/
GSC_SITE_URL=https://www.daybydayconsulting.com/

# ===== IndexNow =====
# Your IndexNow API key (32-char hex). Stored in scripts/indexnow.mjs as a constant
# for now; TODO: rotate to env var (tracked in pipeline TODO doc).
# INDEXNOW_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Cloudflare (Pages auto-deploy) =====
# Not env vars — set in Cloudflare dashboard. The repo's cloudflare.toml publishes "." 
# with build command `echo using prebuilt static files`. Auto-deploy triggers on push 
# to main via the Cloudflare GitHub integration (configured outside this repo).

# ===== GitHub (CI workflows) =====
# The blog-daily.yml workflow needs no secrets if the repo is public.
# If you later move scripts to push from CI, add:
# GH_TOKEN=ghp_xxx           # fine-grained PAT with contents:write on this repo
# GIT_AUTHOR_NAME=DayByDay Bot
# GIT_AUTHOR_EMAIL=bot@daybyday.local

# ===== n8n (optional, for orchestrator) =====
# n8n host + API key for the orchestrator workflows. Used by n8n -> GitHub Actions webhook.
# N8N_HOST=https://n8n.yourdomain.com
# N8N_API_KEY=your_n8n_api_key

# ===== Notifications (optional) =====
# Telegram bot for daily-publish + failure alerts.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# TELEGRAM_CHAT_ID=-1001234567890